---
layout: layouts/base.njk
title: Private
permalink: /private/
---

<section class="private-page">
  <div class="private-wrap">

    <div class="private-board private-board--animating" id="privateBoard">
      <div class="private-cell"></div>
      <div class="private-cell"></div>
      <div class="private-cell"></div>

      <div class="private-cell"></div>

      <div class="private-cell private-cell--gate" id="privateGateCell">
        <div class="private-gate" id="privateGate">
          <p class="private-kicker">private archive</p>
          <h1 class="private-title">not all frames are meant to be seen.</h1>
          <p class="private-text">enter to continue.</p>

          <form class="private-form" id="privateForm" novalidate>
            <input
              type="password"
              id="privatePassword"
              class="private-input"
              placeholder="password"
              autocomplete="current-password"
            >
            <button class="private-button" type="submit">enter</button>
          </form>

          <p class="private-error" id="privateError" aria-live="polite"></p>
        </div>
      </div>

      <div class="private-cell"></div>

      <div class="private-cell"></div>
      <div class="private-cell"></div>
      <div class="private-cell"></div>
    </div>

    <div class="private-content private-content--hidden" id="privateContent">
      <div class="private-head">
        <p class="private-kicker">private archive</p>
        <h2 class="private-title">unlocked.</h2>
        <p class="private-text">hidden frames will appear here later.</p>
      </div>

      <div class="private-grid">
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
      </div>
    </div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const HASH = "b33500f5b628db5ac1cc34651f20bb249f1bd27d6bbdc82e8b62d78847774163";

  const messages = [
    "not this one.",
    "wrong frame.",
    "almost, but not quite.",
    "that’s not the key.",
    "nice try.",
    "nope, not this archive.",
    "this frame stays hidden.",
    "close, but still locked."
  ];

  const board = document.getElementById("privateBoard");
  const cells = Array.from(board.querySelectorAll(".private-cell"));
  const gate = document.getElementById("privateGate");
  const form = document.getElementById("privateForm");
  const input = document.getElementById("privatePassword");
  const error = document.getElementById("privateError");
  const content = document.getElementById("privateContent");

  let lastMessage = "";

  function randomMessage() {
    let next = "";
    let tries = 0;
    do {
      next = messages[Math.floor(Math.random() * messages.length)];
      tries++;
    } while (next === lastMessage && tries < 20);
    lastMessage = next;
    return next;
  }

  async function sha256(value) {
    const data = new TextEncoder().encode(value);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map(b => b.toString(16).padStart(2, "0")).join("");
  }

  function introAnimation() {
    const movable = cells.filter(el => !el.classList.contains("private-cell--gate"));

    movable.forEach((cell, i) => {
      const row = Math.floor(i / 3);
      const col = i % 3;

      const dx = (col - 1) * (18 + Math.random() * 18);
      const dy = (row - 1) * (18 + Math.random() * 18);

      cell.style.transform = `translate(${dx}px, ${dy}px)`;
    });

    requestAnimationFrame(() => {
      setTimeout(() => {
        cells.forEach(cell => {
          cell.style.transform = "translate(0,0)";
        });
      }, 120);

      setTimeout(() => {
        board.classList.remove("private-board--animating");
        board.classList.add("private-board--ready");
        input.focus();
      }, 920);
    });
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const value = input.value.trim();
    if (!value) {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
      return;
    }

    const hashed = await sha256(value);

    if (hashed === HASH) {
      board.classList.add("private-board--unlocking");

      setTimeout(() => {
        content.classList.remove("private-content--hidden");
        content.classList.add("private-content--visible");
      }, 280);
    } else {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
    }
  });

  introAnimation();
});
</script>
