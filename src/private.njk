---
layout: layouts/base.njk
title: Private
permalink: /private/
---

<section class="private-page">
  <div class="private-wrap">

    <!-- RUSTIGE LAYOUT -->
    <div class="private-gate private-gate--hidden" id="privateGate">
      <p class="private-kicker">private archive</p>
      <h1 class="private-title">not all frames are meant to be seen.</h1>
      <p class="private-text">enter to continue.</p>

      <form class="private-form" id="privateForm" novalidate>
        <input type="password" id="privatePassword" class="private-input" placeholder="password">
        <button class="private-button" type="submit">enter</button>
      </form>

      <p class="private-error" id="privateError"></p>
    </div>

    <!-- INTRO PUZZLE -->
    <div class="private-intro-overlay" id="privateIntroOverlay">
      <div class="private-intro-grid" id="privateIntroGrid">

        {% for i in [0,1,2,3,5,6,7,8] %}
          <div class="private-intro-tile"
               data-piece="{{ i }}"
               style="--piece-col:{{ i % 3 }}; --piece-row:{{ (i / 3) | int }};">
          </div>
        {% endfor %}

        <!-- center piece -->
        <div class="private-intro-tile private-intro-tile--final"
             id="privateIntroFinal"
             data-piece="4"
             style="--piece-col:1; --piece-row:1;">
        </div>

      </div>
    </div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const overlay = document.getElementById("privateIntroOverlay");
  const grid = document.getElementById("privateIntroGrid");
  const finalTile = document.getElementById("privateIntroFinal");
  const gate = document.getElementById("privateGate");

  const tiles = Array.from(grid.querySelectorAll(".private-intro-tile:not(.private-intro-tile--final)"));
  const allTiles = Array.from(grid.querySelectorAll(".private-intro-tile"));

  function wait(ms){ return new Promise(r => setTimeout(r, ms)); }

  const clamp01 = x => Math.max(0, Math.min(1, x));
  const lerp = (a,b,t)=>a+(b-a)*t;
  const smoothstep = t=>{ t=clamp01(t); return t*t*(3-2*t); };
  const curve = t=>smoothstep(Math.min(t,0.93));

  const durAt = t => Math.round(lerp(160,50,curve(t)));
  const gapAt = t => Math.round(lerp(95,20,curve(t)));

  function neighbors(i){
    const r=Math.floor(i/3), c=i%3, n=[];
    if(c>0)n.push(i-1);
    if(c<2)n.push(i+1);
    if(r>0)n.push(i-3);
    if(r<2)n.push(i+3);
    return n;
  }

  function runIntro(){
    const rect = grid.getBoundingClientRect();
    const size = rect.width;

    const startGap = 6;
    const endGap = 0;

    const startCell = (size - startGap*2)/3;
    const endCell = size/3;

    const map = {};
    allTiles.forEach(t => map[Number(t.dataset.piece)] = t);

    function pos(i,gap,cell){
      return {
        x:(i%3)*(cell+gap),
        y:Math.floor(i/3)*(cell+gap)
      };
    }

    function place(tile,i,gap,cell,dur=0,scale=1,op=1){
      const p = pos(i,gap,cell);
      tile.style.width = cell+"px";
      tile.style.height = cell+"px";
      tile.style.transition = dur
        ? `transform ${dur}ms cubic-bezier(.2,1,.3,1), opacity ${Math.max(120, dur)}ms ease, width ${dur}ms cubic-bezier(.2,1,.3,1), height ${dur}ms cubic-bezier(.2,1,.3,1)`
        : "none";
      tile.style.transform = `translate(${p.x}px,${p.y}px) scale(${scale})`;
      tile.style.opacity = op;
    }

    // solved state met midden leeg
    let state = [0,1,2,3,null,5,6,7,8];
    let blank = 4;
    let prev = -1;
    const moves=[];

    // shuffle
    for(let k=0;k<14;k++){
      const opts = neighbors(blank).filter(n=>n!==prev);
      const pick = opts[Math.floor(Math.random()*opts.length)];
      moves.push(pick);
      prev = blank;
      [state[blank],state[pick]]=[state[pick],state[blank]];
      blank=pick;
    }

    // initial render
    state.forEach((p,i)=>{
      if(p!==null) place(map[p],i,startGap,startCell);
    });

    place(finalTile,4,startGap,startCell,0,0.76,0);

    setTimeout(async()=>{

      // solve reverse
      for(let step=moves.length-1; step>=0; step--){
        const t = 1-(step/(moves.length-1));
        let dur = durAt(t);
        let gap = gapAt(t);

        // laatste slide move sneller
        if(step===0){
          dur = Math.round(dur*0.42);
          gap = 0;
        }

        const from = moves[step];
        const piece = state[from];
        if(piece===null) continue;

        place(map[piece],blank,startGap,startCell,dur);

        await wait(dur);

        [state[blank],state[from]]=[state[from],state[blank]];
        blank=from;

        if (gap > 0) await wait(gap);
      }

      // laatste middenstuk: snel + click
      place(finalTile,4,startGap,startCell,110,1.08,1);
      await wait(120);

      place(finalTile,4,startGap,startCell,90,0.97,1);
      await wait(95);

      place(finalTile,4,startGap,startCell,70,1,1);
      finalTile.classList.add("private-intro-tile--click");
      await wait(90);
      finalTile.classList.remove("private-intro-tile--click");

      // merge
      for(let i=0;i<9;i++){
        place(map[i],i,endGap,endCell,320);
      }

      await wait(340);

      // glow
      grid.classList.add("private-intro-grid--glow");

      await wait(620);

      overlay.classList.add("private-intro-overlay--done");
      gate.classList.remove("private-gate--hidden");
      gate.classList.add("private-gate--visible");
    },120);
  }

  runIntro();
});
</script>
