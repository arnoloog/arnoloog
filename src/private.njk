---
layout: layouts/base.njk
title: Private
permalink: /private/
---

<section class="private-page">
  <div class="private-wrap">

    <!-- RUSTIGE ECHTE LAYOUT -->
    <div class="private-gate private-gate--hidden" id="privateGate">
      <p class="private-kicker">private archive</p>
      <h1 class="private-title">not all frames are meant to be seen.</h1>
      <p class="private-text">enter to continue.</p>

      <form class="private-form" id="privateForm" novalidate>
        <input
          type="password"
          id="privatePassword"
          class="private-input"
          placeholder="password"
          autocomplete="current-password"
        >
        <button id="privateSubmit" class="private-button" type="submit">
          enter
        </button>
      </form>

      <p class="private-error" id="privateError" aria-live="polite"></p>
    </div>

    <!-- INTRO OVERLAY -->
    <div class="private-intro-overlay" id="privateIntroOverlay" aria-hidden="true">
      <div class="private-intro-grid" id="privateIntroGrid">
        <div class="private-intro-tile" data-piece="0" style="--piece-col:0; --piece-row:0;"></div>
        <div class="private-intro-tile" data-piece="1" style="--piece-col:1; --piece-row:0;"></div>
        <div class="private-intro-tile" data-piece="2" style="--piece-col:2; --piece-row:0;"></div>
        <div class="private-intro-tile" data-piece="3" style="--piece-col:0; --piece-row:1;"></div>

        <!-- middenstuk verschijnt pas op het einde -->
        <div class="private-intro-tile private-intro-tile--final" id="privateIntroFinal" data-piece="4" style="--piece-col:1; --piece-row:1;"></div>

        <div class="private-intro-tile" data-piece="5" style="--piece-col:2; --piece-row:1;"></div>
        <div class="private-intro-tile" data-piece="6" style="--piece-col:0; --piece-row:2;"></div>
        <div class="private-intro-tile" data-piece="7" style="--piece-col:1; --piece-row:2;"></div>
        <div class="private-intro-tile" data-piece="8" style="--piece-col:2; --piece-row:2;"></div>
      </div>
    </div>

    <!-- CONTENT NA JUIST WW -->
    <div class="private-content private-content--hidden" id="privateContent">
      <div class="private-head">
        <p class="private-kicker">private archive</p>
        <h2 class="private-title">unlocked.</h2>
        <p class="private-text">hidden frames will appear here later.</p>
      </div>

      <div class="private-grid">
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
      </div>
    </div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  // als je huidige hash al werkt, laat die gerust zo
  const HASH = "b33500f5b628db5ac1cc34651f20bb249f1bd27d6bbdc82e8b62d78847774163";

  const messages = [
    "not this one.",
    "wrong frame.",
    "almost, but not quite.",
    "that’s not the key.",
    "nice try.",
    "nope, not this archive.",
    "this frame stays hidden.",
    "close, but still locked."
  ];

  const overlay = document.getElementById("privateIntroOverlay");
  const introGrid = document.getElementById("privateIntroGrid");
  const finalTile = document.getElementById("privateIntroFinal");
  const gate = document.getElementById("privateGate");
  const form = document.getElementById("privateForm");
  const input = document.getElementById("privatePassword");
  const error = document.getElementById("privateError");
  const content = document.getElementById("privateContent");

  if (!overlay || !introGrid || !finalTile || !gate || !form || !input || !error || !content) return;

  const movingTiles = Array.from(introGrid.querySelectorAll(".private-intro-tile:not(.private-intro-tile--final)"));
  const allTiles = Array.from(introGrid.querySelectorAll(".private-intro-tile"));

  let lastMessage = "";

  function randomMessage() {
    let next = "";
    let tries = 0;
    do {
      next = messages[Math.floor(Math.random() * messages.length)];
      tries++;
    } while (next === lastMessage && tries < 20);
    lastMessage = next;
    return next;
  }

  async function sha256(value) {
    const data = new TextEncoder().encode(value);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map((b) => b.toString(16).padStart(2, "0")).join("");
  }

  function wait(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }

  function clamp01(x) {
    return Math.max(0, Math.min(1, x));
  }

  function lerp(a, b, t) {
    return a + (b - a) * t;
  }

  function smoothstep(t) {
    t = clamp01(t);
    return t * t * (3 - 2 * t);
  }

  function curve(t) {
    return smoothstep(Math.min(t, 0.93));
  }

  function durAt(t) {
    const u = curve(t);
    return Math.round(lerp(160, 50, u));
  }

  function gapAt(t) {
    const u = curve(t);
    return Math.round(lerp(95, 20, u));
  }

  function neighbors(i) {
    const res = [];
    const row = Math.floor(i / 3);
    const col = i % 3;
    if (col > 0) res.push(i - 1);
    if (col < 2) res.push(i + 1);
    if (row > 0) res.push(i - 3);
    if (row < 2) res.push(i + 3);
    return res;
  }

  async function runIntro() {
    const boardRect = introGrid.getBoundingClientRect();
    const boardSize = boardRect.width;
    const startGap = 6;
    const endGap = 0;
    const startCell = (boardSize - startGap * 2) / 3;
    const endCell = boardSize / 3;

    const tileByPiece = {};
    allTiles.forEach((tile) => {
      const piece = Number(tile.dataset.piece);
      tileByPiece[piece] = tile;
    });

    function posToXY(pos, gap, cell) {
      const row = Math.floor(pos / 3);
      const col = pos % 3;
      return {
        x: col * (cell + gap),
        y: row * (cell + gap)
      };
    }

    function frameTile(tile, pos, gap, cell, duration = 0, opacity = 1, scale = 1) {
      const { x, y } = posToXY(pos, gap, cell);
      tile.style.width = `${cell}px`;
      tile.style.height = `${cell}px`;
      tile.style.transition = duration
        ? `transform ${duration}ms cubic-bezier(.2, 1, .3, 1), opacity ${duration}ms ease, width ${duration}ms cubic-bezier(.2, 1, .3, 1), height ${duration}ms cubic-bezier(.2, 1, .3, 1)`
        : "none";
      tile.style.transform = `translate(${x}px, ${y}px) scale(${scale})`;
      tile.style.opacity = opacity;
    }

    // solved state met leeg midden
    let state = [0, 1, 2, 3, null, 5, 6, 7, 8];
    let blank = 4;
    let prev = -1;
    const moves = [];

    // shuffle via echte slide-puzzle moves
    for (let k = 0; k < 14; k++) {
      const options = neighbors(blank).filter((n) => n !== prev);
      const pick = options[Math.floor(Math.random() * options.length)];
      moves.push(pick);
      prev = blank;
      [state[blank], state[pick]] = [state[pick], state[blank]];
      blank = pick;
    }

    // start in geshuffelde toestand
    for (let pos = 0; pos < state.length; pos++) {
      const piece = state[pos];
      if (piece === null) continue;
      frameTile(tileByPiece[piece], pos, startGap, startCell, 0, 1, 1);
    }

    // final middle piece al op zijn plek maar onzichtbaar
    frameTile(finalTile, 4, startGap, startCell, 0, 0, 0.88);

    await wait(120);

    // solve reverse — laatste move eindigt dus naar het midden
   for (let step = moves.length - 1; step >= 0; step--) {
  const t = 1 - (step / Math.max(1, moves.length - 1));

  let duration = durAt(t);
  let gapMs = gapAt(t);

  // allerlaatste move sneller en iets strakker
  if (step === 0) {
    duration = Math.round(duration * 0.62);
    gapMs = 8;
  }

  const from = moves[step];
  const piece = state[from];
  if (piece === null) continue;

  frameTile(tileByPiece[piece], blank, startGap, startCell, duration, 1, 1);

  await wait(duration);

  [state[blank], state[from]] = [state[from], state[from] = state[blank]][0], blank = from;
}
    }

    // center piece verschijnt -> alle 9 vakjes compleet
    frameTile(finalTile, 4, startGap, startCell, 260, 1, 1);
    await wait(280);

    // alles smelt samen naar 1 groot slotvlak
    for (let piece = 0; piece <= 8; piece++) {
      frameTile(tileByPiece[piece], piece, endGap, endCell, 420, 1, 1);
    }

    introGrid.classList.add("private-intro-grid--merged");
    await wait(440);

    // glow op heel slot
    introGrid.classList.add("private-intro-grid--glow");
    await wait(760);

    overlay.classList.add("private-intro-overlay--done");
    gate.classList.remove("private-gate--hidden");
    gate.classList.add("private-gate--visible");
    input.focus();
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const value = input.value.trim();
    if (!value) {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
      return;
    }

    const hashed = await sha256(value);

    if (hashed === HASH) {
      gate.classList.remove("private-gate--visible");
      gate.classList.add("private-gate--hidden");

      setTimeout(() => {
        content.classList.remove("private-content--hidden");
        content.classList.add("private-content--visible");
      }, 260);
    } else {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
    }
  });

  runIntro();
});
</script>
