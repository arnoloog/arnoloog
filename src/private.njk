---
layout: layouts/base.njk
title: Private
permalink: /private/
---

<section class="private-page">
  <div class="private-wrap">

    <div class="private-gate private-gate--hidden" id="privateGate">
      <p class="private-kicker">private archive</p>
      <h1 class="private-title">not all frames are meant to be seen.</h1>
      <p class="private-text">enter to continue.</p>

      <form class="private-form" id="privateForm" novalidate>
        <input
          type="password"
          id="privatePassword"
          class="private-input"
          placeholder="password"
          autocomplete="current-password"
        >
        <button class="private-button" type="submit">enter</button>
      </form>

      <p class="private-error" id="privateError" aria-live="polite"></p>
    </div>

    <div class="private-intro-overlay" id="privateIntroOverlay" aria-hidden="true">
      <div class="private-intro-grid" id="privateIntroGrid">
        {% for i in [0,1,2,3,5,6,7,8] %}
          <div
            class="private-intro-tile"
            data-piece="{{ i }}"
            style="--piece-col:{{ i % 3 }}; --piece-row:{{ (i / 3) | int }};"
          ></div>
        {% endfor %}

        <div
          class="private-intro-tile private-intro-tile--final"
          id="privateIntroFinal"
          data-piece="4"
          style="--piece-col:1; --piece-row:1;"
        ></div>
      </div>
    </div>

    <div class="private-content private-content--hidden" id="privateContent">
      <div class="private-head">
        <p class="private-kicker">private archive</p>
        <h2 class="private-title">unlocked.</h2>
        <p class="private-text">hidden frames will appear here later.</p>
      </div>

      <div class="private-grid">
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
      </div>
    </div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const HASH = "b33500f5b628db5ac1cc34651f20bb249f1bd27d6bbdc82e8b62d78847774163";

  const messages = [
    "not this one.",
    "wrong frame.",
    "almost, but not quite.",
    "that’s not the key.",
    "nice try.",
    "nope, not this archive.",
    "this frame stays hidden.",
    "close, but still locked."
  ];

  const overlay = document.getElementById("privateIntroOverlay");
  const grid = document.getElementById("privateIntroGrid");
  const finalTile = document.getElementById("privateIntroFinal");
  const gate = document.getElementById("privateGate");
  const form = document.getElementById("privateForm");
  const input = document.getElementById("privatePassword");
  const error = document.getElementById("privateError");
  const content = document.getElementById("privateContent");

  if (!overlay || !grid || !finalTile || !gate || !form || !input || !error || !content) return;

  const tiles = Array.from(grid.querySelectorAll(".private-intro-tile:not(.private-intro-tile--final)"));
  const allTiles = Array.from(grid.querySelectorAll(".private-intro-tile"));

  let lastMessage = "";
  let introDone = false;

  function randomMessage() {
    let next = "";
    let tries = 0;
    do {
      next = messages[Math.floor(Math.random() * messages.length)];
      tries++;
    } while (next === lastMessage && tries < 20);
    lastMessage = next;
    return next;
  }

  async function sha256(value) {
    const data = new TextEncoder().encode(value);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map((b) => b.toString(16).padStart(2, "0")).join("");
  }

  function wait(ms) {
    return new Promise((resolve) => setTimeout(resolve, ms));
  }

  const clamp01 = (x) => Math.max(0, Math.min(1, x));
  const lerp = (a, b, t) => a + (b - a) * t;
  const smoothstep = (t) => {
    t = clamp01(t);
    return t * t * (3 - 2 * t);
  };
  const curve = (t) => smoothstep(Math.min(t, 0.93));

  const durAt = (t) => Math.round(lerp(160, 55, curve(t)));
  const gapAt = (t) => Math.round(lerp(95, 18, curve(t)));

  async function runIntro() {
    const rect = grid.getBoundingClientRect();
    const size = rect.width;

    const startGap = 6;
    const endGap = 0;

    const startCell = (size - startGap * 2) / 3;
    const endCell = size / 3;

    const map = {};
    allTiles.forEach((tile) => {
      map[Number(tile.dataset.piece)] = tile;
    });

    function pos(index, gap, cell) {
      return {
        x: (index % 3) * (cell + gap),
        y: Math.floor(index / 3) * (cell + gap)
      };
    }

    function place(tile, index, gap, cell, dur = 0, scale = 1, op = 1) {
      const p = pos(index, gap, cell);
      tile.style.width = cell + "px";
      tile.style.height = cell + "px";
      tile.style.transition = dur
        ? `transform ${dur}ms cubic-bezier(.2,1,.3,1), opacity ${Math.max(120, dur)}ms ease, width ${dur}ms cubic-bezier(.2,1,.3,1), height ${dur}ms cubic-bezier(.2,1,.3,1)`
        : "none";
      tile.style.transform = `translate(${p.x}px,${p.y}px) scale(${scale})`;
      tile.style.opacity = op;
    }

    // vaste start-opstelling, midden leeg, stuk 1 onderaan midden
    const startState = {
      0: 2,
      1: 7, // moet als laatste naar boven
      2: 1,
      3: 6,
      5: 5,
      6: 0,
      7: 8,
      8: 3
    };

    Object.entries(startState).forEach(([piece, slot]) => {
      place(map[Number(piece)], slot, startGap, startCell, 0, 1, 1);
    });

    place(finalTile, 4, startGap, startCell, 0, 0.72, 0);

    // vaste volgorde, laatste is ALTIJD bovenste middelste blokje
    const moveOrder = [
      { piece: 0, to: 0 },
      { piece: 2, to: 2 },
      { piece: 3, to: 3 },
      { piece: 6, to: 6 },
      { piece: 7, to: 7 },
      { piece: 8, to: 8 }
    ];

    await wait(140);

    for (let i = 0; i < moveOrder.length; i++) {
      const t = i / Math.max(1, moveOrder.length - 1);
      const dur = durAt(t);
      const gap = gapAt(t);

      const step = moveOrder[i];
      place(map[step.piece], step.to, startGap, startCell, dur);

      await wait(dur);
      await wait(gap);
    }

    // middenstuk snel erin
    place(finalTile, 4, startGap, startCell, 95, 1.07, 1);
    await wait(100);

    place(finalTile, 4, startGap, startCell, 70, 0.98, 1);
    await wait(75);

    place(finalTile, 4, startGap, startCell, 55, 1, 1);
    await wait(60);

    // LAATSTE beweging = stuk 1 van onder naar boven
    const topMiddleStart = pos(7, startGap, startCell);
    const topMiddleEnd = pos(1, startGap, startCell);
    const topMiddleTile = map[1];

    topMiddleTile.style.width = startCell + "px";
    topMiddleTile.style.height = startCell + "px";
    topMiddleTile.style.transition = "none";
    topMiddleTile.style.transform = `translate(${topMiddleStart.x}px,${topMiddleStart.y}px) scale(1)`;
    topMiddleTile.style.opacity = "1";

    await wait(20);

    topMiddleTile.style.transition = "transform 135ms cubic-bezier(.2,1,.3,1), filter 135ms ease";
    topMiddleTile.style.transform = `translate(${topMiddleEnd.x}px,${topMiddleEnd.y}px) scale(1)`;
    topMiddleTile.classList.add("private-intro-tile--click");

    await wait(145);
    topMiddleTile.classList.remove("private-intro-tile--click");

    // merge naar 1 vlak
    for (let i = 0; i < 9; i++) {
      place(map[i], i, endGap, endCell, 300);
    }

    await wait(320);

    // glow
    grid.classList.add("private-intro-grid--glow");
    await wait(640);

    overlay.classList.add("private-intro-overlay--done");
    gate.classList.remove("private-gate--hidden");
    gate.classList.add("private-gate--visible");

    introDone = true;
    input.focus();
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    if (!introDone) return;

    const value = input.value.trim();

    if (!value) {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
      return;
    }

    const hashed = await sha256(value);

    if (hashed === HASH) {
      error.textContent = "";
      gate.classList.remove("private-gate--visible");
      gate.classList.add("private-gate--hidden");

      setTimeout(() => {
        content.classList.remove("private-content--hidden");
        content.classList.add("private-content--visible");
      }, 260);
    } else {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
    }
  });

  runIntro();
});
</script>
