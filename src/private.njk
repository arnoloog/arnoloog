---
layout: layouts/base.njk
title: Private
permalink: /private/
---

<section class="private-page">
  <div class="private-wrap">

    <!-- RUSTIGE ECHTE LAYOUT -->
    <div class="private-gate private-gate--hidden" id="privateGate">
      <p class="private-kicker">private archive</p>
      <h1 class="private-title">not all frames are meant to be seen.</h1>
      <p class="private-text">enter to continue.</p>

      <form class="private-form" id="privateForm" novalidate>
        <input
          type="password"
          id="privatePassword"
          class="private-input"
          placeholder="password"
          autocomplete="current-password"
        >
        <button id="privateSubmit" class="private-button" type="submit">
          enter
        </button>
      </form>

      <p class="private-error" id="privateError" aria-live="polite"></p>
    </div>

    <!-- INTRO OVERLAY -->
    <div class="private-intro-overlay" id="privateIntroOverlay" aria-hidden="true">
  <div class="private-intro-grid" id="privateIntroGrid">
    <div class="private-intro-tile" data-piece="0" style="--piece-col:0; --piece-row:0;"></div>
    <div class="private-intro-tile" data-piece="1" style="--piece-col:1; --piece-row:0;"></div>
    <div class="private-intro-tile" data-piece="2" style="--piece-col:2; --piece-row:0;"></div>
    <div class="private-intro-tile" data-piece="3" style="--piece-col:0; --piece-row:1;"></div>
    <div class="private-intro-tile" data-piece="4" style="--piece-col:1; --piece-row:1;"></div>
    <div class="private-intro-tile" data-piece="5" style="--piece-col:2; --piece-row:1;"></div>
    <div class="private-intro-tile" data-piece="6" style="--piece-col:0; --piece-row:2;"></div>
    <div class="private-intro-tile" data-piece="7" style="--piece-col:1; --piece-row:2;"></div>

    <!-- laatste stukje van het slot: verschijnt pas op het einde -->
    <div class="private-intro-tile private-intro-tile--final" id="privateIntroFinal" style="--piece-col:2; --piece-row:2;"></div>
  </div>
</div>

    <!-- CONTENT NA JUIST WW -->
    <div class="private-content private-content--hidden" id="privateContent">
      <div class="private-head">
        <p class="private-kicker">private archive</p>
        <h2 class="private-title">unlocked.</h2>
        <p class="private-text">hidden frames will appear here later.</p>
      </div>

      <div class="private-grid">
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
        <div class="private-item private-item--placeholder"></div>
      </div>
    </div>

  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const HASH = "b33500f5b628db5ac1cc34651f20bb249f1bd27d6bbdc82e8b62d78847774163";

  const messages = [
    "not this one.",
    "wrong frame.",
    "almost, but not quite.",
    "that’s not the key.",
    "nice try.",
    "nope, not this archive.",
    "this frame stays hidden.",
    "close, but still locked."
  ];

  const overlay = document.getElementById("privateIntroOverlay");
  const introGrid = document.getElementById("privateIntroGrid");
  const introTiles = Array.from(introGrid.querySelectorAll(".private-intro-tile"));

  const gate = document.getElementById("privateGate");
  const form = document.getElementById("privateForm");
  const input = document.getElementById("privatePassword");
  const error = document.getElementById("privateError");
  const content = document.getElementById("privateContent");

  let lastMessage = "";

  function randomMessage() {
    let next = "";
    let tries = 0;
    do {
      next = messages[Math.floor(Math.random() * messages.length)];
      tries++;
    } while (next === lastMessage && tries < 20);
    lastMessage = next;
    return next;
  }

  async function sha256(value) {
    const data = new TextEncoder().encode(value);
    const hashBuffer = await crypto.subtle.digest("SHA-256", data);
    const hashArray = Array.from(new Uint8Array(hashBuffer));
    return hashArray.map((b) => b.toString(16).padStart(2, "0")).join("");
  }

  function runIntro() {
    introTiles.forEach((tile) => {
      const dx = (Math.random() - 0.5) * 220;
      const dy = (Math.random() - 0.5) * 220;
      const rot = (Math.random() - 0.5) * 12;

      tile.style.transform = `translate(${dx}px, ${dy}px) rotate(${rot}deg)`;
      tile.style.opacity = "0.78";
    });

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        setTimeout(() => {
          introTiles.forEach((tile) => {
            tile.style.transform = "translate(0,0) rotate(0deg)";
            tile.style.opacity = "1";
          });
        }, 120);

        setTimeout(() => {
          overlay.classList.add("private-intro-overlay--done");
          gate.classList.remove("private-gate--hidden");
          gate.classList.add("private-gate--visible");
          input.focus();
        }, 1150);
      });
    });
  }

  form.addEventListener("submit", async (e) => {
    e.preventDefault();

    const value = input.value.trim();
    if (!value) {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
      return;
    }

    const hashed = await sha256(value);

    if (hashed === HASH) {
      gate.classList.remove("private-gate--visible");
      gate.classList.add("private-gate--hidden");

      setTimeout(() => {
        content.classList.remove("private-content--hidden");
        content.classList.add("private-content--visible");
      }, 260);
    } else {
      error.textContent = randomMessage();
      input.value = "";
      input.focus();
    }
  });

  runIntro();
});
</script>
