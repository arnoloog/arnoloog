<script>
document.addEventListener("DOMContentLoaded", () => {

  const images = [
    {% for roll in photos.rolls %}
      {% for i in range(1, 120) %}
        {
          src: "/photos/rolls/{{ roll.name }}/roll{{ roll.name | slice(-2) }}-full-{{ "%02d"|format(i) }}.webp",
          roll: "{{ roll.name }}"
        },
      {% endfor %}
    {% endfor %}
  ];

  let current = null;

  const viewer = document.getElementById("viewer");
  const meta = document.getElementById("meta");

  function imageExists(url) {
    return new Promise(resolve => {
      const img = new Image();
      img.onload = () => resolve(true);
      img.onerror = () => resolve(false);
      img.src = url;
    });
  }

  async function pickRandom() {
    let next;
    let exists = false;
    let tries = 0;

    while (!exists && tries < 30) {
      next = images[Math.floor(Math.random() * images.length)];
      exists = await imageExists(next.src);
      tries++;
    }

    if (!exists) return;

    current = next;

    viewer.style.opacity = 0;

    setTimeout(() => {
      viewer.src = next.src;
      meta.textContent = next.roll;
      viewer.style.opacity = 1;
    }, 120);
  }

  pickRandom();

  document.addEventListener("click", (e) => {
    if (e.target.closest(".nav-icon, .logo")) return;
    pickRandom();
  });

});
</script>
