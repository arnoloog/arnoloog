---
layout: layouts/base.njk
title: Discovery
permalink: /discovery/
---

<section class="discovery">
  <img id="viewer" class="discovery-img" src="" alt="">

  <div class="discovery-overlay">
    <div class="discovery-meta" id="meta"></div>
    <div class="discovery-hint" id="hint">tap to explore</div>
  </div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const images = [
    {% for roll in photos.rolls %}
      {% for img in roll.full %}
        {
          src: "{{ img }}",
          roll: "{{ roll.name }}",
          year: "{{ roll.year }}"
        },
      {% endfor %}
    {% endfor %}
  ];

  const viewer = document.getElementById("viewer");
  const meta = document.getElementById("meta");
  const hint = document.getElementById("hint");

  if (!viewer || !meta || !hint || !images.length) {
    console.warn("Discovery: geen full images gevonden.");
    return;
  }

  let session = [];
  let index = 0;
  let ended = false;

  function preload(src) {
    const img = new Image();
    img.src = src;
  }

  function shuffle(list) {
    const arr = [...list];

    for (let i = arr.length - 1; i > 0; i--) {
      const j = Math.floor(Math.random() * (i + 1));
      [arr[i], arr[j]] = [arr[j], arr[i]];
    }

    return arr;
  }

  function formatRollLabel(img) {
    const rollLabel = img.roll
      .replace(/^\d{4}-/, "")
      .replace("roll", "roll ");

    return `${img.year} · ${rollLabel}`;
  }

  function startSession() {
    session = shuffle(images);
    index = 0;
    ended = false;
    hint.textContent = "tap to explore";
    showNext();
  }

  function showEnd() {
  ended = true;

  viewer.style.opacity = "0";

  setTimeout(() => {
    viewer.removeAttribute("src");
    viewer.alt = "";

    meta.innerHTML = `
      <div class="discovery-end">
        <p class="discovery-end__kicker">end of discovery</p>
        <h1 class="discovery-end__title">you made it through the archive.</h1>
        <p class="discovery-end__text">
          thanks for wandering all the way through. the frames will reshuffle when you're ready.
        </p>
      </div>
    `;

    hint.textContent = "tap to shuffle again";
    viewer.style.opacity = "1";
  }, 120);
}

  function showNext() {
    if (ended) {
      startSession();
      return;
    }

    if (index >= session.length) {
      showEnd();
      return;
    }

    const next = session[index];
    index++;

    preload(next.src);

    viewer.style.opacity = "0";

    setTimeout(() => {
      viewer.src = next.src;
      viewer.alt = next.roll;

      meta.textContent = `${formatRollLabel(next)} · ${index}/${session.length}`;
      hint.textContent = "tap to explore";

      viewer.style.opacity = "1";
    }, 120);
  }

  startSession();

  viewer.addEventListener("click", () => {
    showNext();
  });

  let startX = 0;

  document.addEventListener("touchstart", (e) => {
    startX = e.touches[0].clientX;
  }, { passive: true });

  document.addEventListener("touchend", (e) => {
    const endX = e.changedTouches[0].clientX;
    if (Math.abs(endX - startX) > 40) {
      showNext();
    }
  }, { passive: true });

  document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight" || e.key === " " || e.key === "Enter") {
      e.preventDefault();
      showNext();
    }
  });
});
</script>
