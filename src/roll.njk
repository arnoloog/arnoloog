---
layout: layouts/base.njk
pagination:
  data: photos.rolls
  size: 1
  alias: roll
permalink: "rolls/{{ roll.name }}/"
---

<article class="roll-page">
  <header class="roll-header">
    <p class="roll-meta-primary">
      {{ roll.name | upper }}{% if roll.location %} · {{ roll.location }}{% endif %}
    </p>

    {% if roll.film or roll.camera %}
      <p class="roll-meta-secondary">
        {% if roll.film %}{{ roll.film }}{% endif %}{% if roll.film and roll.camera %} · {% endif %}{% if roll.camera %}{{ roll.camera }}{% endif %}
      </p>
    {% endif %}
  </header>

  <section class="roll-gallery">
    {% for img in roll.full %}
      <figure class="roll-photo">
        <img src="{{ img }}" loading="lazy" alt="">
      </figure>
    {% endfor %}
  </section>
</article>
